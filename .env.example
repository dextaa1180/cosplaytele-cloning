# Supabase server-side integration
# Create these in Supabase Project Settings > API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public bucket used for thumbnails, hero images, and preview media.
SUPABASE_STORAGE_BUCKET=tunacosplay-media

# Public website origin used to generate browser-facing storage URLs.
# For self-hosted Supabase behind Nginx, keep SUPABASE_URL internal and set this to the site domain.
PUBLIC_STORAGE_BASE_URL=https://tunacosplay.site

# Optional. When set, preview videos are uploaded to DoodStream and stored as embed URLs.
# Images still use Supabase Storage.
DOODSTREAM_API_KEY=

# Optional. Sends a channel message when a post is first published.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_POST_LABEL=ASUPAN
TELEGRAM_SHOP_URL=https://tunakaslana.shop/
PUBLIC_SITE_URL=https://tunacosplay.site

# Admin login for /tuna-signin -> /tuna-console.
ADMIN_USERNAME=admin
# Generate with:
# node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('your-password')).then(b=>console.log([...new Uint8Array(b)].map(x=>x.toString(16).padStart(2,'0')).join('')))"
ADMIN_PASSWORD_HASH=
# Random session signing secret. Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=
